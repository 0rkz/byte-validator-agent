# byte-validator-agent — environment template
# Copy to .env and fill in values. .env is gitignored.

# Chain / RPC
RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
RPC_URL_FALLBACK=https://sepolia-rollup.arbitrum.io/rpc
POLL_INTERVAL_MS=4000
LOOKBACK_BLOCKS=50000

# Validator identity (v0.3) — generated by `npm run genkey`
# VALIDATOR_PRIVATE_KEY=0x...
# VALIDATOR_ADDRESS=0x...
# 200 PPB at 18 decimals
STAKE_AMOUNT_WEI=200000000000000000000

# On-chain write loops (all default OFF — flip one at a time after verifying)
AUTO_REGISTER=false
HEARTBEAT_ENABLED=false
SUBMIT_ENABLED=false
# Beat slightly under 1h (HEARTBEAT_INTERVAL); submit aligned to BATCH_INTERVAL.
HEARTBEAT_INTERVAL_MS=3300000
SUBMIT_INTERVAL_MS=86400000

# Payload archive — directory where publisher daemons (broadcast_helper.py)
# write per-broadcast JSON envelopes. Relative paths resolve against the
# validator-agent's working directory. In a typical multi-repo layout where
# data-feeds/ lives alongside validator-agent/, use ../data-feeds/archive.
PAYLOAD_ARCHIVE_DIR=../data-feeds/archive
ENDPOINT_URL=https://payperbyte.io/validator/agent-v01

# LLM strategy: claude | ollama | hybrid
LLM_STRATEGY=hybrid
# ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# Scoring cadence (60s for dev, 86400000 for prod-aligned 24h)
SCORING_INTERVAL_MS=60000

LOG_LEVEL=info
